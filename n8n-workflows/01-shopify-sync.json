{
  "name": "ADM - Shopify Data Sync",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [{ "field": "hours", "hoursInterval": 24, "triggerAtHour": 3 }]
        }
      },
      "id": "cron-trigger",
      "name": "Daily 3AM UTC",
      "type": "n8n-nodes-base.scheduleTrigger",
      "position": [240, 300]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "=https://{{$credentials.shopifyStoreUrl}}/admin/api/2024-01/orders.json",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "X-Shopify-Access-Token", "value": "={{$credentials.shopifyAccessToken}}" }
          ]
        },
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            { "name": "status", "value": "any" },
            { "name": "created_at_min", "value": "={{$now.minus({days: 2}).toISO()}}" },
            { "name": "limit", "value": "250" }
          ]
        }
      },
      "id": "fetch-orders",
      "name": "Fetch Shopify Orders",
      "type": "n8n-nodes-base.httpRequest",
      "position": [460, 200]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "=https://{{$credentials.shopifyStoreUrl}}/admin/api/2024-01/products.json",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "X-Shopify-Access-Token", "value": "={{$credentials.shopifyAccessToken}}" }
          ]
        }
      },
      "id": "fetch-products",
      "name": "Fetch Products/SKUs",
      "type": "n8n-nodes-base.httpRequest",
      "position": [460, 400]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "=https://{{$credentials.shopifyStoreUrl}}/admin/api/2024-01/inventory_levels.json",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "X-Shopify-Access-Token", "value": "={{$credentials.shopifyAccessToken}}" }
          ]
        }
      },
      "id": "fetch-inventory",
      "name": "Fetch Inventory Levels",
      "type": "n8n-nodes-base.httpRequest",
      "position": [460, 600]
    },
    {
      "parameters": {
        "jsCode": "const orders = $input.all().map(item => item.json);\nconst transformed = [];\n\nfor (const order of orders) {\n  if (!order.line_items) continue;\n  for (const item of order.line_items) {\n    transformed.push({\n      order_id: String(order.id),\n      order_date: order.created_at.split('T')[0],\n      sku_id: item.sku || item.variant_id,\n      quantity: item.quantity,\n      gross_revenue: parseFloat(item.price) * item.quantity,\n      net_revenue: parseFloat(item.price) * item.quantity - parseFloat(item.total_discount || '0'),\n      discount_amount: parseFloat(item.total_discount || '0'),\n      customer_type: order.customer?.orders_count > 1 ? 'returning' : 'new',\n      subscription_type: item.properties?.some(p => p.name === 'subscription_id') ? 'subscription' : 'one-time',\n      channel: 'D2C/Shopify',\n      synced_at: new Date().toISOString()\n    });\n  }\n}\n\nreturn transformed.map(t => ({ json: t }));"
      },
      "id": "transform-orders",
      "name": "Transform Orders",
      "type": "n8n-nodes-base.code",
      "position": [700, 200]
    },
    {
      "parameters": {
        "operation": "upsert",
        "tableId": "shopify_orders",
        "conflictColumns": "order_id",
        "dataMode": "autoMap"
      },
      "id": "upsert-orders",
      "name": "Upsert to Supabase",
      "type": "n8n-nodes-base.supabase",
      "position": [920, 200]
    },
    {
      "parameters": {
        "operation": "upsert",
        "tableId": "shopify_inventory",
        "conflictColumns": "sku_id,location_id,snapshot_date",
        "dataMode": "autoMap"
      },
      "id": "upsert-inventory",
      "name": "Upsert Inventory",
      "type": "n8n-nodes-base.supabase",
      "position": [920, 600]
    },
    {
      "parameters": {
        "errorMessage": "Shopify Sync Failed",
        "maxTries": 3,
        "waitBetweenTries": 5000
      },
      "id": "error-handler",
      "name": "Error Handler",
      "type": "n8n-nodes-base.errorTrigger",
      "position": [920, 800]
    }
  ],
  "connections": {
    "Daily 3AM UTC": { "main": [[{ "node": "Fetch Shopify Orders", "type": "main", "index": 0 }, { "node": "Fetch Products/SKUs", "type": "main", "index": 0 }, { "node": "Fetch Inventory Levels", "type": "main", "index": 0 }]] },
    "Fetch Shopify Orders": { "main": [[{ "node": "Transform Orders", "type": "main", "index": 0 }]] },
    "Transform Orders": { "main": [[{ "node": "Upsert to Supabase", "type": "main", "index": 0 }]] },
    "Fetch Inventory Levels": { "main": [[{ "node": "Upsert Inventory", "type": "main", "index": 0 }]] }
  },
  "settings": {
    "saveManualExecutions": true,
    "callerPolicy": "workflowsFromSameOwner",
    "errorWorkflow": "error-handler"
  }
}
